+    # === DFLASH FP8 / TransformerEngine wrap helpers ===
+    def _maybe_wrap_te(self):
+        """Wrap self.model with TransformerEngine for FP8 training, if configured.
+
+        Driven by:
+          - self.config.fp8_recipe_kind  ("" / "bf16" / "current_fp8" / "mxfp8" / ...)
+          - self.config.te_use_fused     (also fuse Qwen3 MLPs into te.LayerNormMLP)
+
+        Sets self._fp8_recipe (TE recipe instance, or None) for later use in the
+        train/val forward wrappers. Idempotent: safe to call twice (no-op).
+        """
+        self._fp8_recipe = None
+        kind = (self.config.fp8_recipe_kind or "").strip().lower()
+        if kind in ("", "bf16", "none"):
+            return
+        # Lazy import so a TE-less environment can still load this module and run bf16 training.
+        import os as _os
+
+        if self.config.te_use_fused:
+            _os.environ["TE_USE_FUSED"] = "1"
+        try:
+            from dflash_llama.training.te_wrap import (
+                TE_VERSION,
+                fusion_coverage,
+                get_recipe,
+                wrap_with_te,
+            )
+        except ImportError as e:
+            raise RuntimeError(
+                "fp8_recipe_kind is set but dflash_llama.training.te_wrap could not be "
+                f"imported: {e}. Install dflash-llama (pip install -e <path-to-repo>) or "
+                "set fp8_recipe_kind='' to fall back to bf16."
+            )
+        before = fusion_coverage(self.model)["summary"]
+        wrap_with_te(self.model, fp8=True)
+        self._fp8_recipe = get_recipe(kind)
+        liger_version = None
+        if (
+            self.config.liger_fused_linear_ce
+            or self.config.liger_rope
+            or self.config.liger_rms_norm
+        ):
+            try:
+                from dflash_llama.training.liger_wrap import LIGER_VERSION, apply_liger
+            except ImportError as e:
+                raise RuntimeError(
+                    "Liger was requested but dflash_llama.training.liger_wrap could not be "
+                    f"imported: {e}. Install dflash-llama (pip install -e <path-to-repo>) or "
+                    "disable the --liger-* flags."
+                )
+            apply_liger(
+                self.model,
+                fused_linear_ce=self.config.liger_fused_linear_ce,
+                rope=self.config.liger_rope,
+                rms_norm=self.config.liger_rms_norm,
+            )
+            liger_version = LIGER_VERSION
+        after = fusion_coverage(self.model)["summary"]
+        root_logger.info(
+            f"[FP8] TE_VERSION={TE_VERSION} recipe={self._fp8_recipe} "
+            f"fused={self.config.te_use_fused} "
+            f"liger_fused_linear_ce={self.config.liger_fused_linear_ce} "
+            f"liger_rope={self.config.liger_rope} "
+            f"liger_rms_norm={self.config.liger_rms_norm} "
+            f"LIGER_VERSION={liger_version} "
+            f"coverage_before={before} coverage_after={after}"
+        )
+        if self.local_rank == 0:
+            # Print on rank 0 too — the logger may be filtered in some configs and this
+            # line is the verification marker we grep for at launch.
+            print(
+                f"[FP8] TE_VERSION={TE_VERSION} recipe={self._fp8_recipe} "
+                f"fused={self.config.te_use_fused} "
+                f"liger_fused_linear_ce={self.config.liger_fused_linear_ce} "
+                f"liger_rope={self.config.liger_rope} "
+                f"liger_rms_norm={self.config.liger_rms_norm} "
+                f"LIGER_VERSION={liger_version} "
+                f"coverage_before={before} coverage_after={after}",
+                flush=True,
+            )
+
+    def _fp8_context(self):
+        """Return a TE fp8_autocast context manager if recipe is set, else nullcontext."""
+        import contextlib as _cl
+
+        rec = getattr(self, "_fp8_recipe", None)
+        if rec is None:
+            return _cl.nullcontext()
+        try:
+            import transformer_engine.pytorch as te
+
+            return te.fp8_autocast(enabled=True, fp8_recipe=rec)
+        except ImportError:
+            return _cl.nullcontext()
+
+    def _fp8_train_forward(self, gpu_batch):
+        with self._fp8_context():
+            return self.model(**gpu_batch, **self.config.train_call_kwargs)
+
+    def _fp8_val_forward(self, gpu_batch):
+        with self._fp8_context():
+            return self.model(**gpu_batch, **self.config.val_call_kwargs)
+
